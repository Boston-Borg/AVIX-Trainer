# Copy this file to `.env` and paste your real keys on the right side of the =
# DO NOT commit the real .env to git. The .gitignore already excludes it.

# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-goes-here

# Get your free Voyage embedding key from https://www.voyageai.com/
# Used to embed FAA reference text for RAG (retrieval-augmented generation).
VOYAGE_API_KEY=pa-your-voyage-key-goes-here

# Optional: override which Claude model to use.
CLAUDE_MODEL=claude-sonnet-4-6

# Optional: which Voyage embedding model to use.
# voyage-3 = best quality, voyage-3-lite = faster + smaller.
VOYAGE_MODEL=voyage-3

# Optional: port for local development (Render sets this automatically).
PORT=8000

# --- Supabase (user accounts + saved data) ---------------------------------
# Get from Supabase dashboard → Project Settings → API Keys
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx_or_eyJ_xxx
# Service role key (backend webhooks only — never expose to browser)
SUPABASE_SERVICE_KEY=sb_secret_xxx_or_eyJ_xxx

# --- Stripe (subscription billing) -----------------------------------------
# Stripe dashboard → Developers → API keys (in TEST MODE for dev)
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe dashboard → Products → your $20/mo product → copy Price ID
STRIPE_PRICE_ID=price_xxx
# Stripe dashboard → Developers → Webhooks → Add endpoint → copy signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Redirect URLs after Checkout (change to your real domain in prod)
STRIPE_SUCCESS_URL=http://localhost:8000/?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:8000/?checkout=cancel

# Owner allowlist — comma-separated emails that bypass the paywall.
# Leave blank in production except for founder/co-founder accounts.
OWNER_EMAILS=you@example.com,cofounder@example.com
